# Copy to .env and fill in your keys. .env is gitignored.
# Load before starting the API: source .env  (from repo root)

# Polygon.io / Massive.com — required for quotes, daily, and intraday stock data
MASSIVE_API_KEY=
# Optional: if you get 404s from api.massive.com, try: MASSIVE_BASE_URL=https://api.polygon.io
# MASSIVE_BASE_URL=
UNUSUAL_WHALES_API_KEY=
FMP_API_KEY=
FINNHUB_API_KEY=
